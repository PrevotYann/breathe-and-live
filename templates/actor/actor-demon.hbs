<form class="bl actor-demon flexcol {{#unless canEdit}}bl-readonly{{/unless}}" autocomplete="off">
  <header class="sheet-header flexrow">
    <img class="profile" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" />
    <div class="header-fields">
      <div class="hero-topline">
        {{#if supplement1934Active}}<div class="eyebrow">Supplement 1934 actif{{#unless supplement1934Global}} sur cette fiche uniquement{{/unless}}</div>{{/if}}
        <div class="eyebrow">Classe jouable - Demon - {{system.class.rank}}</div>
        <div class="eyebrow">Actions: {{system.combat.actionEconomy.actionsPerTurn}} - Deplacement: {{system.combat.actionEconomy.effectiveMovementMeters}} m</div>
      </div>
      <h1 class="charname">
        <input name="name" type="text" value="{{actor.name}}" {{#unless canEdit}}disabled{{/unless}} />
      </h1>
      <div class="grid four-col summary-grid">
        <div class="field small">
          <label>Rang</label>
          <select name="system.class.rank" {{#unless canEdit}}disabled{{/unless}}>
            {{#each rankOptions as |rank|}}
              <option value="{{rank}}" {{#if (eq ../system.class.rank rank)}}selected{{/if}}>{{rank}}</option>
            {{/each}}
          </select>
        </div>
        <div class="field small">
          <label>Niveau</label>
          <input type="number" name="system.class.level" value="{{system.class.level}}" min="1" disabled />
          <small>Auto selon le rang</small>
        </div>
        <div class="field small">
          <label>Lignee</label>
          <input type="text" list="bl-demon-bloodlines" name="system.demonology.sharedBloodline" value="{{system.demonology.sharedBloodline}}" placeholder="Branche / lune" {{#unless canEdit}}disabled{{/unless}} />
          <datalist id="bl-demon-bloodlines">
            {{#each demonBloodlineOptions as |opt|}}
              <option value="{{opt}}"></option>
            {{/each}}
          </datalist>
          <small>Suggestions du supplement 1934</small>
        </div>
        <div class="field small">
          <label>Style</label>
          <input type="text" name="system.profile.combatStyle" value="{{system.profile.combatStyle}}" {{#unless canEdit}}disabled{{/unless}} />
        </div>
      </div>
    </div>
  </header>

  <section class="field action-strip">
    <div class="grid bl-demon-action-grid">
      <button type="button" class="bl-action-basic-attack">Attaque de base</button>
      {{#each demonQuickAttacks as |it|}}
        <button type="button" class="bl-demon-basic-attack" data-item-id="{{it.itemId}}" data-attack-key="{{it.key}}" data-attack-name="{{it.name}}" data-attack-damage="{{it.damage}}" data-attack-range="{{it.range}}">{{it.name}}</button>
      {{/each}}
      <button type="button" class="bl-action-sprint">Sprinter</button>
      <button type="button" class="bl-action-wait">Attendre</button>
      <button type="button" class="bl-action-rest">Repos</button>
      <button type="button" class="bl-action-counter">Riposte 1 RP</button>
      <button type="button" class="bl-action-counter-assured">Coup assure 2 RP</button>
    </div>
  </section>

  <nav class="sheet-tabs tabs" data-group="primary">
    <a class="item" data-tab="sheet">Fiche</a>
    <a class="item" data-tab="techniques">Arts demoniaques</a>
    <a class="item" data-tab="inventaire">Inventaire</a>
    <a class="item" data-tab="regles">Corps & regles</a>
  </nav>

  <section class="sheet-body">
    <div class="tab" data-group="primary" data-tab="sheet">
      <div class="grid four-col">
        <div class="res core-resource">
          <label>PV</label>
          <div class="pair">
            <input type="number" name="system.resources.hp.value" value="{{system.resources.hp.value}}" min="0" {{#unless canEdit}}disabled{{/unless}} />
            <span>/</span>
            <input type="number" name="system.resources.hp.max" value="{{system.resources.hp.max}}" min="0" {{#unless canEdit}}disabled{{/unless}} />
          </div>
          <small>Base corps: {{system.resources.hp.base}}</small>
        </div>
        <div class="res core-resource">
          <label>BDP</label>
          <div class="pair">
            <input type="number" name="system.resources.bdp.value" value="{{system.resources.bdp.value}}" min="0" {{#unless canEdit}}disabled{{/unless}} />
            <span>/</span>
            <input type="number" name="system.resources.bdp.max" value="{{system.resources.bdp.max}}" min="0" {{#unless canEdit}}disabled{{/unless}} />
          </div>
          <small>10 x Courage</small>
        </div>
        <div class="res core-resource">
          <label>RP</label>
          <div class="pair">
            <input type="number" name="system.resources.rp.value" value="{{system.resources.rp.value}}" min="0" {{#unless canEdit}}disabled{{/unless}} />
            <span>/</span>
            <input type="number" name="system.resources.rp.max" value="{{system.resources.rp.max}}" min="0" {{#unless canEdit}}disabled{{/unless}} />
          </div>
          <small>Regle demon: RP calcules puis divises par 2</small>
        </div>
        <div class="res core-resource">
          <label>CA</label>
          <input type="number" name="system.resources.ca" value="{{system.resources.ca}}" min="0" {{#unless canEdit}}disabled{{/unless}} />
          <small>Attaque de base: {{system.demonology.basicDamage}}</small>
        </div>
      </div>

      {{#if demonQuickAttacks.length}}
        <div class="field">
          <h3>Attaques de base</h3>
          <div class="shared-actions">
            {{#each demonQuickAttacks as |it|}}
              <div class="shared-action">
                <div>
                  <strong>{{it.name}}</strong>
                  <small>{{#if it.damage}}{{it.damage}}{{else}}-{{/if}} • {{it.range}} m</small>
                </div>
                <button type="button" class="bl-demon-basic-attack" data-item-id="{{it.itemId}}" data-attack-key="{{it.key}}" data-attack-name="{{it.name}}" data-attack-damage="{{it.damage}}" data-attack-range="{{it.range}}">Lancer</button>
              </div>
            {{/each}}
          </div>
        </div>
      {{/if}}

      <div class="grid two-col">
        <div class="field">
          <h3>Caracteristiques</h3>
          <div class="grid stats-base">
            <button type="button" class="bl-roll-base" data-stat="force" data-label="Force">Force</button><input type="number" name="system.stats.base.force" value="{{system.stats.base.force}}" {{#unless canEdit}}disabled{{/unless}} />
            <button type="button" class="bl-roll-base" data-stat="finesse" data-label="Finesse">Finesse</button><input type="number" name="system.stats.base.finesse" value="{{system.stats.base.finesse}}" {{#unless canEdit}}disabled{{/unless}} />
            <button type="button" class="bl-roll-base" data-stat="courage" data-label="Courage">Courage</button><input type="number" name="system.stats.base.courage" value="{{system.stats.base.courage}}" {{#unless canEdit}}disabled{{/unless}} />
            <button type="button" class="bl-roll-base" data-stat="vitesse" data-label="Vitesse">Vitesse</button><input type="number" name="system.stats.base.vitesse" value="{{system.stats.base.vitesse}}" {{#unless canEdit}}disabled{{/unless}} />
            <button type="button" class="bl-roll-base" data-stat="social" data-label="Social">Social</button><input type="number" name="system.stats.base.social" value="{{system.stats.base.social}}" {{#unless canEdit}}disabled{{/unless}} />
            <button type="button" class="bl-roll-base" data-stat="intellect" data-label="Intellect">Intellect</button><input type="number" name="system.stats.base.intellect" value="{{system.stats.base.intellect}}" {{#unless canEdit}}disabled{{/unless}} />
          </div>

          <h3>Competences derivees</h3>
          <div class="grid two-col compact-groups">
            <div class="group">
              <h4>Force <small>{{derivedBudget.force.spent}} / {{derivedBudget.force.base}} depenses</small></h4>
              {{#each derived.groups.force as |k|}}
                <button type="button" class="bl-roll-derived" data-derived="{{k}}" data-label="{{lookup ../derived.labels k}}">{{lookup ../derived.labels k}}</button>
                <input type="number" name="system.stats.derived.{{k}}" value="{{lookup ../system.stats.derived k}}" min="0" {{#unless ../canEdit}}disabled{{/unless}} />
              {{/each}}
            </div>
            <div class="group">
              <h4>Finesse <small>{{derivedBudget.finesse.spent}} / {{derivedBudget.finesse.base}} depenses</small></h4>
              {{#each derived.groups.finesse as |k|}}
                <button type="button" class="bl-roll-derived" data-derived="{{k}}" data-label="{{lookup ../derived.labels k}}">{{lookup ../derived.labels k}}</button>
                <input type="number" name="system.stats.derived.{{k}}" value="{{lookup ../system.stats.derived k}}" min="0" {{#unless ../canEdit}}disabled{{/unless}} />
              {{/each}}
            </div>
            <div class="group">
              <h4>Courage <small>{{derivedBudget.courage.spent}} / {{derivedBudget.courage.base}} depenses</small></h4>
              {{#each derived.groups.courage as |k|}}
                <button type="button" class="bl-roll-derived" data-derived="{{k}}" data-label="{{lookup ../derived.labels k}}">{{lookup ../derived.labels k}}</button>
                <input type="number" name="system.stats.derived.{{k}}" value="{{lookup ../system.stats.derived k}}" min="0" {{#unless ../canEdit}}disabled{{/unless}} />
              {{/each}}
            </div>
            <div class="group">
              <h4>Vitesse <small>{{derivedBudget.vitesse.spent}} / {{derivedBudget.vitesse.base}} depenses</small></h4>
              {{#each derived.groups.vitesse as |k|}}
                <button type="button" class="bl-roll-derived" data-derived="{{k}}" data-label="{{lookup ../derived.labels k}}">{{lookup ../derived.labels k}}</button>
                <input type="number" name="system.stats.derived.{{k}}" value="{{lookup ../system.stats.derived k}}" min="0" {{#unless ../canEdit}}disabled{{/unless}} />
              {{/each}}
            </div>
            <div class="group">
              <h4>Social <small>{{derivedBudget.social.spent}} / {{derivedBudget.social.base}} depenses</small></h4>
              {{#each derived.groups.social as |k|}}
                <button type="button" class="bl-roll-derived" data-derived="{{k}}" data-label="{{lookup ../derived.labels k}}">{{lookup ../derived.labels k}}</button>
                <input type="number" name="system.stats.derived.{{k}}" value="{{lookup ../system.stats.derived k}}" min="0" {{#unless ../canEdit}}disabled{{/unless}} />
              {{/each}}
            </div>
            <div class="group">
              <h4>Intellect <small>{{derivedBudget.intellect.spent}} / {{derivedBudget.intellect.base}} depenses</small></h4>
              {{#each derived.groups.intellect as |k|}}
                <button type="button" class="bl-roll-derived" data-derived="{{k}}" data-label="{{lookup ../derived.labels k}}">{{lookup ../derived.labels k}}</button>
                <input type="number" name="system.stats.derived.{{k}}" value="{{lookup ../system.stats.derived k}}" min="0" {{#unless ../canEdit}}disabled{{/unless}} />
              {{/each}}
            </div>
          </div>
        </div>

        <div class="field">
          <h3>Corps demoniaque</h3>
          <div class="rule-pills">
            <div class="rule-pill">
              <span>Budget creation</span>
              <strong>{{demonCreationBudget.spent}} / {{demonCreationBudget.max}}</strong>
              <small>{{#if demonCreationBudget.valid}}Restant: {{demonCreationBudget.remaining}}{{else}}Budget depasse{{/if}}</small>
            </div>
          </div>
          <button type="button" class="bl-apply-demon-creation">Appliquer creation demon</button>
          <div class="grid two-col">
            <div>
              <label>Type de corps</label>
              <select name="system.demonology.bodyType" {{#unless canEdit}}disabled{{/unless}}>
                {{#each demonBodyOptions as |opt|}}
                  <option value="{{opt.key}}" {{#if (eq ../system.demonology.bodyType opt.key)}}selected{{/if}}>{{opt.label}} - {{opt.points}} pt(s)</option>
                {{/each}}
              </select>
              <label>PV de depart du corps</label>
              <input type="number" name="system.demonology.baseHpChoice" value="{{system.demonology.baseHpChoice}}" min="1" {{#unless canEdit}}disabled{{/unless}} />

              <label>Deplacement</label>
              <select name="system.demonology.movementType" {{#unless canEdit}}disabled{{/unless}}>
                {{#each demonMovementOptions as |opt|}}
                  <option value="{{opt.key}}" {{#if (eq ../system.demonology.movementType opt.key)}}selected{{/if}}>{{opt.label}} - {{opt.points}} pt(s)</option>
                {{/each}}
              </select>
              <label>Base mouvement (m)</label>
              <input type="number" name="system.demonology.movementBase" value="{{system.demonology.movementBase}}" min="0" step="0.5" {{#unless canEdit}}disabled{{/unless}} />
            </div>
            <div>
              <label>Dangerosite</label>
              <select name="system.demonology.dangerLevel" {{#unless canEdit}}disabled{{/unless}}>
                {{#each demonDangerOptions as |opt|}}
                  <option value="{{opt.key}}" {{#if (eq ../system.demonology.dangerLevel opt.key)}}selected{{/if}}>{{opt.label}} - {{opt.points}} pt(s)</option>
                {{/each}}
              </select>
              <label>Degats de base</label>
              <input type="text" name="system.demonology.basicDamage" value="{{system.demonology.basicDamage}}" {{#unless canEdit}}disabled{{/unless}} />

              <label><input type="checkbox" name="system.demonology.canInfect" data-dtype="Boolean" {{checked system.demonology.canInfect}} {{#unless canEdit}}disabled{{/unless}} /> Peut infecter</label>
              <label><input type="checkbox" name="system.demonology.canExecute" data-dtype="Boolean" {{checked system.demonology.canExecute}} {{#unless canEdit}}disabled{{/unless}} /> Peut executer un humain a 5 PV</label>
              <label>Notes</label>
              <textarea name="system.progression.notes" rows="3" {{#unless canEdit}}disabled{{/unless}}>{{system.progression.notes}}</textarea>
            </div>
          </div>

          <h3>Palier du rang</h3>
          {{#if demonRankPackage}}
            <div class="stat-benchmark-grid">
              {{#each demonRankPackageLabels as |row|}}
                <div class="benchmark-chip">
                  <span>{{row.label}}</span>
                  <strong>+{{row.value}}</strong>
                </div>
              {{/each}}
            </div>
          {{else}}
            <p class="hint">Aucun paquet de rang connu pour ce demon.</p>
          {{/if}}

          <h3>Rappels de regles</h3>
          <div class="rule-pills">
            <div class="rule-pill">
              <span>Creation</span>
              <strong>0 / 1 / 2 / 3 / 3 / 5 + rang</strong>
            </div>
            <div class="rule-pill">
              <span>PV</span>
              <strong>Corps + (5 x Force)</strong>
            </div>
            <div class="rule-pill">
              <span>BDP</span>
              <strong>10 x Courage</strong>
            </div>
            <div class="rule-pill">
              <span>RP</span>
              <strong>(5 + Vit + Int) / 2</strong>
            </div>
            <div class="rule-pill">
              <span>Endurance</span>
              <strong>Aucune pour les demons</strong>
            </div>
            <div class="rule-pill">
              <span>Degats stat</span>
              <strong>Force / Finesse a moitie</strong>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="tab" data-group="primary" data-tab="techniques">
      <div class="field">
        <label>Recherche</label>
        <input type="text" data-tech-filter placeholder="Nom, type, art sanguinaire..." />
      </div>
      <header class="list-header">
        <div>Nom</div><div>Famille</div><div>Portee</div><div>Cout</div><div>Degats</div><div></div>
      </header>
      <ol class="item-list">
        {{#each itemsTech as |it|}}
          <li class="item technique-item" data-item-id="{{it.id}}" data-search="{{it.name}} {{it.type}} {{it.system.breath}}">
            <div class="name"><a class="item-edit">{{it.name}}</a></div>
            <div>{{it.type}}</div>
            <div>{{it.system.range}}</div>
            <div>{{#if it.system.costBdp}}BDP {{it.system.costBdp}}{{else}}{{it.system.costE}}{{/if}}</div>
            <div>{{#if it.system.damage}}{{it.system.damage}}{{else}}-{{/if}}</div>
            <div class="controls">
              {{#if it.blUsable}}
                <a class="item-control item-chat" title="Utiliser"><i class="fas fa-burst"></i></a>
              {{/if}}
              <a class="item-control item-edit" title="Ouvrir"><i class="fas fa-pen-to-square"></i></a>
              <a class="item-control item-delete" title="Supprimer"><i class="fas fa-trash"></i></a>
            </div>
          </li>
        {{/each}}
      </ol>
    </div>

    <div class="tab" data-group="primary" data-tab="inventaire">
      <div class="grid two-col">
        <div class="field">
          <h3>Poison actif</h3>
          <div class="rule-pills">
            <div class="rule-pill">
              <span>{{activePoisonSummary.title}}</span>
              <strong>{{#if activePoisonSummary.active}}Dose prete{{else}}Aucune dose{{/if}}</strong>
              {{#each activePoisonSummary.lines as |line|}}
                <small>{{line}}</small>
              {{/each}}
            </div>
          </div>
          {{#if activePoisonSummary.active}}
            <button type="button" class="bl-clear-poison">Retirer l'enduction</button>
          {{/if}}
        </div>
        <div class="field">
          <h3>Etat du poison</h3>
          <div class="rule-pills">
            <div class="rule-pill">
              <span>{{poisonStateSummary.profileLabel}}</span>
              <strong>{{poisonStateSummary.intensity}} niveau(x)</strong>
              <small>{{poisonStateSummary.effectSummary}}</small>
              {{#if poisonStateSummary.restrictionSummary}}<small>{{poisonStateSummary.restrictionSummary}}</small>{{/if}}
            </div>
          </div>
        </div>
      </div>

      <h3>Poisons</h3>
      <header class="list-header">
        <div>Nom</div><div>Profil</div><div></div>
      </header>
      <ol class="item-list">
        {{#each itemsPoisons as |it|}}
          <li class="item" data-item-id="{{it.id}}">
            <div class="name"><a class="item-edit">{{it.name}}</a><br><small>{{it.blChargeLabel}}</small></div>
            <div>{{it.blProfileLabel}}</div>
            <div class="controls">
              <a class="item-control bl-apply-poison" title="Enduire une arme"><i class="fas fa-vial"></i></a>
              <a class="item-control item-edit" title="Ouvrir"><i class="fas fa-pen-to-square"></i></a>
              <a class="item-control item-delete" title="Supprimer"><i class="fas fa-trash"></i></a>
            </div>
          </li>
        {{/each}}
      </ol>

      <header class="list-header">
        <div>Nom</div><div>Type</div><div></div>
      </header>
      <ol class="item-list">
        {{#each itemsInventory as |it|}}
          <li class="item" data-item-id="{{it.id}}">
            <div class="name"><a class="item-edit">{{it.name}}</a></div>
            <div>{{it.type}}</div>
            <div class="controls">
              <a class="item-control item-edit" title="Ouvrir"><i class="fas fa-pen-to-square"></i></a>
              <a class="item-control item-delete" title="Supprimer"><i class="fas fa-trash"></i></a>
            </div>
          </li>
        {{/each}}
      </ol>
    </div>

    <div class="tab" data-group="primary" data-tab="regles">
      <div class="grid three-col">
        <div class="field">
          <h3>Repere bestiaire du livre</h3>
          <p class="hint">Valeurs de reference pour un demon de ce rang. Elles ne remplacent pas automatiquement les formules de la fiche.</p>
          <div class="benchmark-table">
            {{#each demonBenchmarkRows as |row|}}
              <div class="benchmark-row">
                <span>{{row.label}}</span>
                <strong>{{row.value}}</strong>
              </div>
            {{/each}}
          </div>
          <div class="benchmark-table benchmark-attacks">
            <div class="benchmark-row"><span>PV / CA</span><strong>{{demonRankBenchmark.hp}} / {{demonRankBenchmark.ca}}</strong></div>
            <div class="benchmark-row"><span>Morsure</span><strong>{{demonRankBenchmark.bite}}</strong></div>
            <div class="benchmark-row"><span>Griffure</span><strong>{{demonRankBenchmark.claw}}</strong></div>
            <div class="benchmark-row"><span>BDA</span><strong>{{demonRankBenchmark.bda}}</strong></div>
            <div class="benchmark-row"><span>RP repere</span><strong>{{demonRankBenchmark.rp}}</strong></div>
          </div>
        </div>

        <div class="field">
          <h3>Actions demoniaques</h3>
          <div class="shared-actions">
            {{#each demonSharedActions as |action|}}
              <div class="shared-action">
                <div>
                  <strong>{{action.label}}</strong>
                  <small>{{action.note}}</small>
                </div>
                <div class="controls">
                  <span>{{action.cost}}</span>
                  {{#if action.available}}
                    {{#if action.automatable}}
                      <button type="button" class="bl-demon-shared-action" data-action-key="{{action.key}}">Utiliser</button>
                    {{else}}
                      <span class="hint">Via reaction</span>
                    {{/if}}
                  {{else}}
                    <span class="hint">Rang insuffisant</span>
                  {{/if}}
                </div>
              </div>
            {{/each}}
          </div>
        </div>

        <div class="field">
          <h3>Conditions & mutilation</h3>
          <div class="condition-list">
            {{#each conditionEntries as |entry|}}
              <div class="condition-row">
                <label><input type="checkbox" name="system.conditions.{{entry.key}}.active" data-dtype="Boolean" {{checked entry.state.active}} {{#unless ../canEdit}}disabled{{/unless}} /> {{entry.label}}</label>
                <input type="number" name="system.conditions.{{entry.key}}.intensity" value="{{entry.state.intensity}}" min="0" {{#unless ../canEdit}}disabled{{/unless}} />
                <input type="number" name="system.conditions.{{entry.key}}.duration" value="{{entry.state.duration}}" min="0" {{#unless ../canEdit}}disabled{{/unless}} />
              </div>
            {{/each}}
          </div>
          <div class="grid two-col panel-stack">
            {{#each limbEntries as |entry|}}
              <div class="field">
                <strong>{{entry.label}}</strong>
                <small>Seuil {{entry.thresholdPercent}}% - suivi: {{entry.targetedDamage}}</small>
                <label><input type="checkbox" name="system.combat.injuries.limbs.{{entry.key}}.injured" data-dtype="Boolean" {{checked entry.state.injured}} {{#unless ../canEdit}}disabled{{/unless}} /> Blesse</label>
                <label><input type="checkbox" name="system.combat.injuries.limbs.{{entry.key}}.broken" data-dtype="Boolean" {{checked entry.state.broken}} {{#unless ../canEdit}}disabled{{/unless}} /> Casse</label>
                <label><input type="checkbox" name="system.combat.injuries.limbs.{{entry.key}}.severed" data-dtype="Boolean" {{checked entry.state.severed}} {{#unless ../canEdit}}disabled{{/unless}} /> Sectionne</label>
              </div>
            {{/each}}
          </div>
        </div>
      </div>
    </div>
  </section>
</form>
