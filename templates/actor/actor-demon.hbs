<form class="bl actor-demon flexcol {{#unless canEdit}}bl-readonly{{/unless}}" autocomplete="off">
  <header class="sheet-header flexrow">
    <img class="profile" src="{{actor.img}}" data-edit="img" title="{{actor.name}}"/>
    <div class="header-fields">
      <h1 class="charname"><input name="name" type="text" value="{{actor.name}}" {{#unless canEdit}}disabled{{/unless}}/></h1>
      <div class="grid two-col">
        <div><label>Classe</label><input type="text" name="system.class.type" value="{{system.class.type}}" placeholder="Démon" {{#unless canEdit}}disabled{{/unless}}/></div>
        <div><label>Niveau</label><input type="number" name="system.class.level" value="{{system.class.level}}" min="1" {{#unless canEdit}}disabled{{/unless}}/></div>
      </div>
    </div>
  </header>

  <nav class="sheet-tabs tabs" data-group="primary">
    <a class="item" data-tab="sheet">Stats & Ressources</a>
    <a class="item" data-tab="techniques">Techniques</a>
    <a class="item" data-tab="inventaire">Inventaire</a>
    <a class="item" data-tab="regles">Règles Démon</a>
  </nav>

  <section class="sheet-body">
    <div class="tab" data-group="primary" data-tab="sheet">
      <div class="grid two-col">
        <div class="grid stats-base">
          <label>Force</label><input type="number" name="system.stats.base.force" value="{{system.stats.base.force}}" {{#unless canEdit}}disabled{{/unless}}/>
          <label>Finesse</label><input type="number" name="system.stats.base.finesse" value="{{system.stats.base.finesse}}" {{#unless canEdit}}disabled{{/unless}}/>
          <label>Courage</label><input type="number" name="system.stats.base.courage" value="{{system.stats.base.courage}}" {{#unless canEdit}}disabled{{/unless}}/>
          <label>Vitesse</label><input type="number" name="system.stats.base.vitesse" value="{{system.stats.base.vitesse}}" {{#unless canEdit}}disabled{{/unless}}/>
          <label>Social</label><input type="number" name="system.stats.base.social" value="{{system.stats.base.social}}" {{#unless canEdit}}disabled{{/unless}}/>
          <label>Intellect</label><input type="number" name="system.stats.base.intellect" value="{{system.stats.base.intellect}}" {{#unless canEdit}}disabled{{/unless}}/>
        </div>
        <div class="grid resources">
          <div class="res"><label>PV</label><input type="number" name="system.resources.hp.value" value="{{system.resources.hp.value}}" {{#unless canEdit}}disabled{{/unless}}/> / <input type="number" name="system.resources.hp.max" value="{{system.resources.hp.max}}" {{#unless canEdit}}disabled{{/unless}}/></div>
          <div class="res"><label>BDP</label><input type="number" name="system.resources.bdp.value" value="{{system.resources.bdp.value}}" {{#unless canEdit}}disabled{{/unless}}/> / <input type="number" name="system.resources.bdp.max" value="{{system.resources.bdp.max}}" {{#unless canEdit}}disabled{{/unless}}/></div>
          <div class="res"><label>Démonisation</label><input type="number" name="system.resources.demonisation" value="{{system.resources.demonisation}}" {{#unless canEdit}}disabled{{/unless}}/></div>
          <div class="res"><label>Actions / tour</label><input type="number" name="system.combat.actionEconomy.actionsPerTurn" value="{{system.combat.actionEconomy.actionsPerTurn}}" {{#unless canEdit}}disabled{{/unless}}/></div>
        </div>
      </div>
    </div>

    <div class="tab" data-group="primary" data-tab="techniques">
      <ol class="item-list">
        {{#each itemsTech as |it|}}
        <li class="item flexrow" data-item-id="{{it.id}}">
          <div class="name"><a class="item-edit">{{it.name}}</a></div>
          {{#if ../canEdit}}<div class="controls"><a class="item-control item-chat" title="Utiliser"><i class="fas fa-burst"></i></a><a class="item-control item-delete" title="Supprimer"><i class="fas fa-trash"></i></a></div>{{/if}}
        </li>
        {{/each}}
      </ol>
    </div>

    <div class="tab" data-group="primary" data-tab="inventaire">
      <ol class="item-list">
        {{#each itemsOther as |it|}}
        <li class="item flexrow" data-item-id="{{it.id}}"><div class="name"><a class="item-edit">{{it.name}}</a></div><div>{{it.type}}</div></li>
        {{/each}}
      </ol>
    </div>

    <div class="tab" data-group="primary" data-tab="regles">
      <label>Blessures / membres</label>
      <textarea name="system.combat.injuries.lostLimbs" rows="3" {{#unless canEdit}}disabled{{/unless}}>{{system.combat.injuries.lostLimbs}}</textarea>
      <label>État vital</label>
      <select name="system.death.state" {{#unless canEdit}}disabled{{/unless}}>
        {{#each deathStates as |st|}}<option value="{{st.value}}" {{#if (eq ../system.death.state st.value)}}selected{{/if}}>{{st.label}}</option>{{/each}}
      </select>
    </div>
  </section>
</form>
