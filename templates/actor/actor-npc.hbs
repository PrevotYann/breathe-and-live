<form class="bl actor-npc flexcol {{#unless canEdit}}bl-readonly{{/unless}}" autocomplete="off">
  <header class="sheet-header flexrow">
    <img class="profile" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" />
    <div class="header-fields">
      <div class="hero-topline">
        {{#if supplement1934Active}}<div class="eyebrow">Supplement 1934 actif{{#unless supplement1934Global}} sur cette fiche uniquement{{/unless}}</div>{{/if}}
        <div class="eyebrow">{{system.class.type}} / {{system.class.rank}}</div>
        <div class="eyebrow">Role: {{system.npc.role}} / Menace: {{system.npc.threat}}</div>
      </div>
      <h1 class="charname">
        <input name="name" type="text" value="{{actor.name}}" {{#unless canEdit}}disabled{{/unless}} />
      </h1>
      <div class="grid four-col summary-grid">
        <div class="field small"><label>Type</label><input type="text" name="system.class.type" value="{{system.class.type}}" {{#unless canEdit}}disabled{{/unless}} /></div>
        <div class="field small"><label>Rang</label><input type="text" name="system.class.rank" value="{{system.class.rank}}" {{#unless canEdit}}disabled{{/unless}} /></div>
        <div class="field small"><label>Role</label><input type="text" name="system.npc.role" value="{{system.npc.role}}" {{#unless canEdit}}disabled{{/unless}} /></div>
        <div class="field small"><label>Menace</label><input type="text" name="system.npc.threat" value="{{system.npc.threat}}" {{#unless canEdit}}disabled{{/unless}} /></div>
      </div>
    </div>
  </header>

  <section class="field action-strip">
    <div class="grid {{#if isNpcDemon}}bl-demon-action-grid{{else}}four-col{{/if}}">
      <button type="button" class="bl-action-basic-attack">Attaque de base</button>
      {{#if isNpcDemon}}
        {{#each demonQuickAttacks as |it|}}
          <button type="button" class="bl-demon-basic-attack" data-item-id="{{it.itemId}}" data-attack-key="{{it.key}}" data-attack-name="{{it.name}}" data-attack-damage="{{it.damage}}" data-attack-range="{{it.range}}">{{it.name}}</button>
        {{/each}}
      {{/if}}
      <button type="button" class="bl-action-sprint">Sprinter</button>
      <button type="button" class="bl-action-wait">Attendre</button>
      <button type="button" class="bl-action-rest">Repos</button>
      <button type="button" class="bl-action-assistance">Assistance</button>
      <button type="button" class="bl-action-kakushi">Kakushi</button>
      <button type="button" class="bl-action-counter">Riposte 1 RP</button>
      <button type="button" class="bl-action-counter-assured">Coup assure 2 RP</button>
    </div>
  </section>

  <nav class="sheet-tabs tabs" data-group="primary">
    <a class="item" data-tab="sheet">Resume</a>
    <a class="item" data-tab="techniques">Techniques</a>
    <a class="item" data-tab="regles">Conditions</a>
  </nav>

  <section class="sheet-body">
    <div class="tab" data-group="primary" data-tab="sheet">
      <div class="grid four-col">
        <div class="res core-resource"><label>PV</label><div class="pair"><input type="number" name="system.resources.hp.value" value="{{system.resources.hp.value}}" {{#unless canEdit}}disabled{{/unless}} /><span>/</span><input type="number" name="system.resources.hp.max" value="{{system.resources.hp.max}}" {{#unless canEdit}}disabled{{/unless}} /></div></div>
        <div class="res core-resource"><label>CA</label><input type="number" name="system.resources.ca" value="{{system.resources.ca}}" {{#unless canEdit}}disabled{{/unless}} /></div>
        <div class="res core-resource"><label>RP</label><div class="pair"><input type="number" name="system.resources.rp.value" value="{{system.resources.rp.value}}" {{#unless canEdit}}disabled{{/unless}} /><span>/</span><input type="number" name="system.resources.rp.max" value="{{system.resources.rp.max}}" {{#unless canEdit}}disabled{{/unless}} /></div></div>
        <div class="res core-resource"><label>BDP</label><div class="pair"><input type="number" name="system.resources.bdp.value" value="{{system.resources.bdp.value}}" {{#unless canEdit}}disabled{{/unless}} /><span>/</span><input type="number" name="system.resources.bdp.max" value="{{system.resources.bdp.max}}" {{#unless canEdit}}disabled{{/unless}} /></div></div>
      </div>

      {{#if isNpcDemon}}
        <div class="field">
          <h3>Creation demon</h3>
          <div class="rule-pills">
            <div class="rule-pill">
              <span>Budget creation</span>
              <strong>{{demonCreationBudget.spent}} / {{demonCreationBudget.max}}</strong>
              <small>{{#if demonCreationBudget.valid}}Restant: {{demonCreationBudget.remaining}}{{else}}Budget depasse{{/if}}</small>
            </div>
          </div>
          <div class="grid three-col">
            <div>
              <label>Corps</label>
              <select name="system.demonology.bodyType" {{#unless canEdit}}disabled{{/unless}}>
                {{#each demonBodyOptions as |opt|}}
                  <option value="{{opt.key}}" {{#if (eq ../system.demonology.bodyType opt.key)}}selected{{/if}}>{{opt.label}} - {{opt.points}} pt(s)</option>
                {{/each}}
              </select>
            </div>
            <div>
              <label>Deplacement</label>
              <select name="system.demonology.movementType" {{#unless canEdit}}disabled{{/unless}}>
                {{#each demonMovementOptions as |opt|}}
                  <option value="{{opt.key}}" {{#if (eq ../system.demonology.movementType opt.key)}}selected{{/if}}>{{opt.label}} - {{opt.points}} pt(s)</option>
                {{/each}}
              </select>
            </div>
            <div>
              <label>Dangerosite</label>
              <select name="system.demonology.dangerLevel" {{#unless canEdit}}disabled{{/unless}}>
                {{#each demonDangerOptions as |opt|}}
                  <option value="{{opt.key}}" {{#if (eq ../system.demonology.dangerLevel opt.key)}}selected{{/if}}>{{opt.label}} - {{opt.points}} pt(s)</option>
                {{/each}}
              </select>
            </div>
          </div>
          <button type="button" class="bl-apply-demon-creation">Appliquer creation demon</button>
        </div>

        {{#if demonQuickAttacks.length}}
          <div class="field">
            <h3>Attaques naturelles</h3>
            <div class="shared-actions">
              {{#each demonQuickAttacks as |it|}}
                <div class="shared-action">
                  <div>
                    <strong>{{it.name}}</strong>
                    <small>{{#if it.damage}}{{it.damage}}{{else}}-{{/if}} • {{it.range}} m</small>
                  </div>
                  <button type="button" class="bl-demon-basic-attack" data-item-id="{{it.itemId}}" data-attack-key="{{it.key}}" data-attack-name="{{it.name}}" data-attack-damage="{{it.damage}}" data-attack-range="{{it.range}}">Lancer</button>
                </div>
              {{/each}}
            </div>
          </div>
        {{/if}}
      {{/if}}

      <div class="grid two-col">
        <div class="field">
          <label>Comportement</label>
          <textarea name="system.npc.behavior" rows="4" {{#unless canEdit}}disabled{{/unless}}>{{system.npc.behavior}}</textarea>
          <label>Butin</label>
          <textarea name="system.npc.loot" rows="3" {{#unless canEdit}}disabled{{/unless}}>{{system.npc.loot}}</textarea>
        </div>
        <div class="field">
          <label>Notes de mort</label>
          <textarea name="system.death.deathNotes" rows="3" {{#unless canEdit}}disabled{{/unless}}>{{system.death.deathNotes}}</textarea>
          <label>Blessures severes</label>
          <input type="number" name="system.combat.injuries.severeWounds" value="{{system.combat.injuries.severeWounds}}" min="0" {{#unless canEdit}}disabled{{/unless}} />
          <label>Conditions libres</label>
          <textarea name="system.combat.injuries.conditions" rows="3" {{#unless canEdit}}disabled{{/unless}}>{{system.combat.injuries.conditions}}</textarea>
        </div>
      </div>
    </div>

    <div class="tab" data-group="primary" data-tab="techniques">
      <header class="list-header">
        <div>Nom</div><div>Type</div><div></div>
      </header>
      <ol class="item-list">
        {{#each itemsTech as |it|}}
          <li class="item" data-item-id="{{it.id}}">
            <div class="name"><a class="item-edit">{{it.name}}</a></div>
            <div>{{it.type}}</div>
            <div class="controls">
              {{#if it.blUsable}}
                <a class="item-control item-chat" title="Utiliser"><i class="fas fa-burst"></i></a>
              {{/if}}
              <a class="item-control item-edit" title="Ouvrir"><i class="fas fa-pen-to-square"></i></a>
              <a class="item-control item-delete" title="Supprimer"><i class="fas fa-trash"></i></a>
            </div>
          </li>
        {{/each}}
      </ol>
    </div>

    <div class="tab" data-group="primary" data-tab="regles">
      <div class="grid two-col">
        <div class="field">
          {{#if isNpcDemon}}
            <h3>Actions demoniaques</h3>
            <div class="shared-actions">
              {{#each demonSharedActions as |action|}}
                <div class="shared-action">
                  <div>
                    <strong>{{action.label}}</strong>
                    <small>{{action.note}}</small>
                  </div>
                  <div class="controls">
                    <span>{{action.cost}}</span>
                    {{#if action.available}}
                      {{#if action.automatable}}
                        <button type="button" class="bl-demon-shared-action" data-action-key="{{action.key}}">Utiliser</button>
                      {{else}}
                        <span class="hint">Via reaction</span>
                      {{/if}}
                    {{else}}
                      <span class="hint">Rang insuffisant</span>
                    {{/if}}
                  </div>
                </div>
              {{/each}}
            </div>
          {{/if}}

          <h3>Conditions</h3>
          {{#each conditionEntries as |entry|}}
            <div class="condition-row">
              <label><input type="checkbox" name="system.conditions.{{entry.key}}.active" data-dtype="Boolean" {{checked entry.state.active}} {{#unless ../canEdit}}disabled{{/unless}} /> {{entry.label}}</label>
              <input type="number" name="system.conditions.{{entry.key}}.intensity" value="{{entry.state.intensity}}" min="0" {{#unless ../canEdit}}disabled{{/unless}} />
              <input type="number" name="system.conditions.{{entry.key}}.duration" value="{{entry.state.duration}}" min="0" {{#unless ../canEdit}}disabled{{/unless}} />
            </div>
          {{/each}}
        </div>
        <div class="field">
          <h3>Membres</h3>
          {{#each limbEntries as |entry|}}
            <div class="limb-row">
              <strong>{{entry.label}}</strong>
              <small>Seuil {{entry.thresholdPercent}}% - suivi: {{entry.targetedDamage}}</small>
              <label><input type="checkbox" name="system.combat.injuries.limbs.{{entry.key}}.injured" data-dtype="Boolean" {{checked entry.state.injured}} {{#unless ../canEdit}}disabled{{/unless}} /> Blesse</label>
              <label><input type="checkbox" name="system.combat.injuries.limbs.{{entry.key}}.broken" data-dtype="Boolean" {{checked entry.state.broken}} {{#unless ../canEdit}}disabled{{/unless}} /> Casse</label>
              <label><input type="checkbox" name="system.combat.injuries.limbs.{{entry.key}}.severed" data-dtype="Boolean" {{checked entry.state.severed}} {{#unless ../canEdit}}disabled{{/unless}} /> Sectionne</label>
            </div>
          {{/each}}
        </div>
      </div>
    </div>
  </section>
</form>
