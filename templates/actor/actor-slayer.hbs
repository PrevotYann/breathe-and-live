<form class="bl actor-slayer flexcol {{#unless canEdit}}bl-readonly{{/unless}}" autocomplete="off">
  <header class="sheet-header flexrow">
    <img class="profile" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" />
    <div class="header-fields">
      <div class="hero-topline">
        {{#if supplement1934Active}}<div class="eyebrow">Supplement 1934 actif{{#unless supplement1934Global}} sur cette fiche uniquement{{/unless}}</div>{{/if}}
        <div class="eyebrow">{{system.class.type}} • {{system.class.rank}}</div>
        <div class="eyebrow">Arme: {{system.profile.primaryWeapon}} • Souffle: {{system.profile.favoredBreath}}</div>
      </div>
      <h1 class="charname">
        <input name="name" type="text" value="{{actor.name}}" placeholder="{{localize 'Name'}}" {{#unless canEdit}}disabled{{/unless}} />
      </h1>
      <div class="grid four-col summary-grid">
        <div class="field small">
          <label>Classe</label>
          <input type="text" name="system.class.type" value="{{system.class.type}}" {{#unless canEdit}}disabled{{/unless}} />
        </div>
        <div class="field small">
          <label>Rang</label>
          <select name="system.class.rank" {{#unless canEdit}}disabled{{/unless}}>
            {{#each rankOptions as |rank|}}
              <option value="{{rank}}" {{#if (eq ../system.class.rank rank)}}selected{{/if}}>{{rank}}</option>
            {{/each}}
          </select>
        </div>
        <div class="field small">
          <label>Niveau</label>
          <input type="number" name="system.class.level" value="{{system.class.level}}" min="1" disabled />
        </div>
        <div class="field small">
          <label>Sous-classe</label>
          <input type="text" name="system.class.subclass" value="{{system.class.subclass}}" placeholder="Voie / posture" {{#unless canEdit}}disabled{{/unless}} />
        </div>
      </div>
    </div>
  </header>

  <section class="field action-strip">
    <div class="grid five-col">
      <button type="button" class="bl-action-basic-attack">Attaque de base</button>
      <button type="button" class="bl-action-recovery">Souffle de recuperation</button>
      <button type="button" class="bl-action-sprint">Sprinter</button>
      <button type="button" class="bl-action-wait">Attendre</button>
      <button type="button" class="bl-action-rest">Repos</button>
      <button type="button" class="bl-action-assistance">Assistance</button>
      <button type="button" class="bl-action-kakushi">Kakushi</button>
      <button type="button" class="bl-starting-equipment">Equipement initial</button>
      <button type="button" class="bl-action-counter">Riposte 1 RP</button>
      <button type="button" class="bl-action-counter-assured">Coup assure 2 RP</button>
      <button type="button" class="bl-action-draw">Degainage 1 RP</button>
      <button type="button" class="bl-action-draw-attack">Degainage+attaque 2 RP</button>
    </div>
  </section>

  <nav class="sheet-tabs tabs" data-group="primary">
    <a class="item" data-tab="sheet">Fiche</a>
    <a class="item" data-tab="breaths">Souffles</a>
    <a class="item" data-tab="techniques">Techniques</a>
    <a class="item" data-tab="inventaire">Inventaire</a>
    <a class="item" data-tab="regles">Regles avancees</a>
  </nav>

  <section class="sheet-body">
    <div class="tab" data-group="primary" data-tab="sheet">
      <div class="grid four-col">
        <div class="res core-resource">
          <label>PV</label>
          <div class="pair">
            <input type="number" name="system.resources.hp.value" value="{{system.resources.hp.value}}" min="0" {{#unless canEdit}}disabled{{/unless}} />
            <span>/</span>
            <input type="number" name="system.resources.hp.max" value="{{system.resources.hp.max}}" min="0" {{#unless canEdit}}disabled{{/unless}} />
          </div>
          <small>Cap de soin: {{system.resources.hp.healableMax}} â€¢ Temp: {{system.resources.hp.temporary}}</small>
        </div>
        <div class="res core-resource">
          <label>Endurance</label>
          <div class="pair">
            <input type="number" name="system.resources.e.value" value="{{system.resources.e.value}}" min="0" {{#unless canEdit}}disabled{{/unless}} />
            <span>/</span>
            <input type="number" name="system.resources.e.max" value="{{system.resources.e.max}}" min="0" {{#unless canEdit}}disabled{{/unless}} />
          </div>
          <small>Temp: {{system.resources.e.temporary}}</small>
        </div>
        <div class="res core-resource">
          <label>RP</label>
          <div class="pair">
            <input type="number" name="system.resources.rp.value" value="{{system.resources.rp.value}}" min="0" {{#unless canEdit}}disabled{{/unless}} />
            <span>/</span>
            <input type="number" name="system.resources.rp.max" value="{{system.resources.rp.max}}" min="0" {{#unless canEdit}}disabled{{/unless}} />
          </div>
        </div>
        <div class="res core-resource">
          <label>CA</label>
          <input type="number" name="system.resources.ca" value="{{system.resources.ca}}" min="0" {{#unless canEdit}}disabled{{/unless}} />
          <small>Arme: {{system.profile.primaryWeapon}}</small>
        </div>
      </div>

      <div class="grid two-col">
        <div>
          <h3>Caracteristiques de base</h3>
          <div class="grid stats-base">
            <button type="button" class="bl-roll-base" data-stat="force" data-label="Force">Force</button><input type="number" name="system.stats.base.force" value="{{system.stats.base.force}}" {{#unless canEdit}}disabled{{/unless}} />
            <button type="button" class="bl-roll-base" data-stat="finesse" data-label="Finesse">Finesse</button><input type="number" name="system.stats.base.finesse" value="{{system.stats.base.finesse}}" {{#unless canEdit}}disabled{{/unless}} />
            <button type="button" class="bl-roll-base" data-stat="courage" data-label="Courage">Courage</button><input type="number" name="system.stats.base.courage" value="{{system.stats.base.courage}}" {{#unless canEdit}}disabled{{/unless}} />
            <button type="button" class="bl-roll-base" data-stat="vitesse" data-label="Vitesse">Vitesse</button><input type="number" name="system.stats.base.vitesse" value="{{system.stats.base.vitesse}}" {{#unless canEdit}}disabled{{/unless}} />
            <button type="button" class="bl-roll-base" data-stat="social" data-label="Social">Social</button><input type="number" name="system.stats.base.social" value="{{system.stats.base.social}}" {{#unless canEdit}}disabled{{/unless}} />
            <button type="button" class="bl-roll-base" data-stat="intellect" data-label="Intellect">Intellect</button><input type="number" name="system.stats.base.intellect" value="{{system.stats.base.intellect}}" {{#unless canEdit}}disabled{{/unless}} />
          </div>
        </div>

        <div>
          <h3>Creation & progression</h3>
          <div class="grid two-col">
            <div class="field">
              <div class="grid two-col">
                <button type="button" class="bl-creation-standard-array">Table 0-5</button>
                <button type="button" class="bl-creation-roll-stats">Tirer 6d6</button>
              </div>
              <label>Methode de stats</label>
              <input type="text" name="system.creation.statMethod" value="{{system.creation.statMethod}}" {{#unless canEdit}}disabled{{/unless}} />
              <label>Jets / valeurs disponibles</label>
              <input type="text" name="system.creation.statRolls" value="{{system.creation.statRolls}}" placeholder="ex: 0, 1, 2, 3, 4, 5" {{#unless canEdit}}disabled{{/unless}} />
              <h4>Points de depart <small>{{creationBudget.starting}} / {{creationBudget.startingMax}}</small></h4>
              <label>Sens extrasensoriels</label>
              <input class="bl-creation-budget-input" data-creation-group="starting" type="number" name="system.creation.sensePoints" value="{{system.creation.sensePoints}}" min="0" {{#unless canEdit}}disabled{{/unless}} />
              <label>Traits surhumains</label>
              <input class="bl-creation-budget-input" data-creation-group="starting" type="number" name="system.creation.superhumanPoints" value="{{system.creation.superhumanPoints}}" min="0" {{#unless canEdit}}disabled{{/unless}} />
              <label>Formes de souffle</label>
              <input class="bl-creation-budget-input" data-creation-group="starting" type="number" name="system.creation.breathFormPoints" value="{{system.creation.breathFormPoints}}" min="0" {{#unless canEdit}}disabled{{/unless}} />
              <small>Restant: {{creationBudget.startingRemaining}}</small>
              <label>Entraineur</label>
              <textarea name="system.profile.trainerContext" rows="2" {{#unless canEdit}}disabled{{/unless}}>{{system.profile.trainerContext}}</textarea>
              <div class="grid three-col">
                <input class="bl-creation-budget-input" data-creation-group="trainer" type="number" name="system.creation.trainerPoints.axis1" value="{{system.creation.trainerPoints.axis1}}" min="0" max="2" {{#unless canEdit}}disabled{{/unless}} />
                <input class="bl-creation-budget-input" data-creation-group="trainer" type="number" name="system.creation.trainerPoints.axis2" value="{{system.creation.trainerPoints.axis2}}" min="0" max="2" {{#unless canEdit}}disabled{{/unless}} />
                <input class="bl-creation-budget-input" data-creation-group="trainer" type="number" name="system.creation.trainerPoints.axis3" value="{{system.creation.trainerPoints.axis3}}" min="0" max="2" {{#unless canEdit}}disabled{{/unless}} />
              </div>
              <small>Entraineur: {{creationBudget.trainer}} / {{creationBudget.contextMax}}</small>
              <label>Partenaire</label>
              <textarea name="system.profile.partnerContext" rows="2" {{#unless canEdit}}disabled{{/unless}}>{{system.profile.partnerContext}}</textarea>
              <div class="grid three-col">
                <input class="bl-creation-budget-input" data-creation-group="partner" type="number" name="system.creation.partnerPoints.axis1" value="{{system.creation.partnerPoints.axis1}}" min="0" max="2" {{#unless canEdit}}disabled{{/unless}} />
                <input class="bl-creation-budget-input" data-creation-group="partner" type="number" name="system.creation.partnerPoints.axis2" value="{{system.creation.partnerPoints.axis2}}" min="0" max="2" {{#unless canEdit}}disabled{{/unless}} />
                <input class="bl-creation-budget-input" data-creation-group="partner" type="number" name="system.creation.partnerPoints.axis3" value="{{system.creation.partnerPoints.axis3}}" min="0" max="2" {{#unless canEdit}}disabled{{/unless}} />
              </div>
              <small>Partenaire: {{creationBudget.partner}} / {{creationBudget.contextMax}}</small>
              <label>Corbeau Kasugai</label>
              <input type="text" name="system.profile.kasugaiCrow" value="{{system.profile.kasugaiCrow}}" {{#unless canEdit}}disabled{{/unless}} />
              <label>Type d'oiseau</label>
              <input type="text" name="system.creation.kasugaiType" value="{{system.creation.kasugaiType}}" {{#unless canEdit}}disabled{{/unless}} />
              <label>Commandes connues</label>
              <input type="text" name="system.creation.kasugaiCommands" value="{{system.creation.kasugaiCommands}}" {{#unless canEdit}}disabled{{/unless}} />
              <div class="grid two-col">
                <button type="button" class="bl-create-kasugai">Creer / ouvrir Kasugai</button>
                <input type="text" name="system.support.companionName" value="{{system.support.companionName}}" placeholder="Compagnon lie" {{#unless canEdit}}disabled{{/unless}} />
              </div>
              <div class="grid three-col">
                <input class="bl-creation-budget-input" data-creation-group="kasugai" type="number" name="system.creation.kasugaiPoints.axis1" value="{{system.creation.kasugaiPoints.axis1}}" min="0" max="2" {{#unless canEdit}}disabled{{/unless}} />
                <input class="bl-creation-budget-input" data-creation-group="kasugai" type="number" name="system.creation.kasugaiPoints.axis2" value="{{system.creation.kasugaiPoints.axis2}}" min="0" max="2" {{#unless canEdit}}disabled{{/unless}} />
                <input class="bl-creation-budget-input" data-creation-group="kasugai" type="number" name="system.creation.kasugaiPoints.axis3" value="{{system.creation.kasugaiPoints.axis3}}" min="0" max="2" {{#unless canEdit}}disabled{{/unless}} />
              </div>
              <small>Kasugai: {{creationBudget.kasugai}} / {{creationBudget.contextMax}}</small>
            </div>
            <div class="field">
              <label>XP</label>
              <div class="pair">
                <input type="number" name="system.progression.xp.value" value="{{system.progression.xp.value}}" min="0" {{#unless canEdit}}disabled{{/unless}} />
                <span>/</span>
                <input type="number" name="system.progression.xp.next" value="{{system.progression.xp.next}}" min="1" {{#unless canEdit}}disabled{{/unless}} />
              </div>
              <label>Points d'entrainement</label>
              <input type="number" name="system.progression.training" value="{{system.progression.training}}" min="0" {{#unless canEdit}}disabled{{/unless}} />
              <label>Emplacements d'etude</label>
              <div class="pair">
                <input type="number" name="system.progression.studySlots.value" value="{{system.progression.studySlots.value}}" min="0" {{#unless canEdit}}disabled{{/unless}} />
                <span>/</span>
                <input type="number" name="system.progression.studySlots.max" value="{{system.progression.studySlots.max}}" min="0" {{#unless canEdit}}disabled{{/unless}} />
              </div>
              <label>Emplacements de competence</label>
              <div class="pair">
                <input type="number" name="system.progression.skillSlots.value" value="{{system.progression.skillSlots.value}}" min="0" {{#unless canEdit}}disabled{{/unless}} />
                <span>/</span>
                <input type="number" name="system.progression.skillSlots.max" value="{{system.progression.skillSlots.max}}" min="0" {{#unless canEdit}}disabled{{/unless}} />
              </div>
              <h4>Competences acquises</h4>
              {{#if itemsProgression.length}}
                <ol class="item-list compact">
                  {{#each itemsProgression as |it|}}
                    <li class="item" data-item-id="{{it.id}}">
                      <div class="name"><a class="item-edit">{{it.name}}</a><br><small>{{it.system.rank}} {{#if it.system.slotCost}}- {{it.system.slotCost}} slot{{/if}}</small></div>
                      <div class="controls">
                        <a class="item-control item-edit" title="Ouvrir"><i class="fas fa-pen-to-square"></i></a>
                        <a class="item-control item-delete" title="Supprimer"><i class="fas fa-trash"></i></a>
                      </div>
                    </li>
                  {{/each}}
                </ol>
              {{else}}
                <small>Glisse une competence depuis le compendium de progression.</small>
              {{/if}}
              <h4>Deblocages superieurs</h4>
              <div class="tag-row">
                {{#each advancedFeatureUnlocks as |unlock|}}
                  <span class="tag">{{unlock.label}}: {{#if unlock.unlocked}}debloque{{else}}rang {{unlock.level}}{{/if}}</span>
                {{/each}}
              </div>
            </div>
          </div>
        </div>
      </div>

      <h3>Competences derivees</h3>
      <div class="grid six-col">
        <div class="group">
          <h4>Force <small>{{derivedBudget.force.spent}} / {{derivedBudget.force.base}} depenses - {{#if derivedBudget.force.over}}depassement {{derivedBudget.force.over}}{{else}}reste {{derivedBudget.force.remaining}}{{/if}}</small></h4>
          {{#each derived.groups.force as |k|}}
            <button type="button" class="bl-roll-derived" data-derived="{{k}}" data-label="{{lookup ../derived.labels k}}">{{lookup ../derived.labels k}}</button>
            <input type="number" name="system.stats.derived.{{k}}" value="{{lookup ../system.stats.derived k}}" min="0" {{#unless ../canEdit}}disabled{{/unless}} />
          {{/each}}
        </div>
        <div class="group">
          <h4>Finesse <small>{{derivedBudget.finesse.spent}} / {{derivedBudget.finesse.base}} depenses - {{#if derivedBudget.finesse.over}}depassement {{derivedBudget.finesse.over}}{{else}}reste {{derivedBudget.finesse.remaining}}{{/if}}</small></h4>
          {{#each derived.groups.finesse as |k|}}
            <button type="button" class="bl-roll-derived" data-derived="{{k}}" data-label="{{lookup ../derived.labels k}}">{{lookup ../derived.labels k}}</button>
            <input type="number" name="system.stats.derived.{{k}}" value="{{lookup ../system.stats.derived k}}" min="0" {{#unless ../canEdit}}disabled{{/unless}} />
          {{/each}}
        </div>
        <div class="group">
          <h4>Courage <small>{{derivedBudget.courage.spent}} / {{derivedBudget.courage.base}} depenses - {{#if derivedBudget.courage.over}}depassement {{derivedBudget.courage.over}}{{else}}reste {{derivedBudget.courage.remaining}}{{/if}}</small></h4>
          {{#each derived.groups.courage as |k|}}
            <button type="button" class="bl-roll-derived" data-derived="{{k}}" data-label="{{lookup ../derived.labels k}}">{{lookup ../derived.labels k}}</button>
            <input type="number" name="system.stats.derived.{{k}}" value="{{lookup ../system.stats.derived k}}" min="0" {{#unless ../canEdit}}disabled{{/unless}} />
          {{/each}}
        </div>
        <div class="group">
          <h4>Vitesse <small>{{derivedBudget.vitesse.spent}} / {{derivedBudget.vitesse.base}} depenses - {{#if derivedBudget.vitesse.over}}depassement {{derivedBudget.vitesse.over}}{{else}}reste {{derivedBudget.vitesse.remaining}}{{/if}}</small></h4>
          {{#each derived.groups.vitesse as |k|}}
            <button type="button" class="bl-roll-derived" data-derived="{{k}}" data-label="{{lookup ../derived.labels k}}">{{lookup ../derived.labels k}}</button>
            <input type="number" name="system.stats.derived.{{k}}" value="{{lookup ../system.stats.derived k}}" min="0" {{#unless ../canEdit}}disabled{{/unless}} />
          {{/each}}
        </div>
        <div class="group">
          <h4>Social <small>{{derivedBudget.social.spent}} / {{derivedBudget.social.base}} depenses - {{#if derivedBudget.social.over}}depassement {{derivedBudget.social.over}}{{else}}reste {{derivedBudget.social.remaining}}{{/if}}</small></h4>
          {{#each derived.groups.social as |k|}}
            <button type="button" class="bl-roll-derived" data-derived="{{k}}" data-label="{{lookup ../derived.labels k}}">{{lookup ../derived.labels k}}</button>
            <input type="number" name="system.stats.derived.{{k}}" value="{{lookup ../system.stats.derived k}}" min="0" {{#unless ../canEdit}}disabled{{/unless}} />
          {{/each}}
        </div>
        <div class="group">
          <h4>Intellect <small>{{derivedBudget.intellect.spent}} / {{derivedBudget.intellect.base}} depenses - {{#if derivedBudget.intellect.over}}depassement {{derivedBudget.intellect.over}}{{else}}reste {{derivedBudget.intellect.remaining}}{{/if}}</small></h4>
          {{#each derived.groups.intellect as |k|}}
            <button type="button" class="bl-roll-derived" data-derived="{{k}}" data-label="{{lookup ../derived.labels k}}">{{lookup ../derived.labels k}}</button>
            <input type="number" name="system.stats.derived.{{k}}" value="{{lookup ../system.stats.derived k}}" min="0" {{#unless ../canEdit}}disabled{{/unless}} />
          {{/each}}
        </div>
      </div>
    </div>

    <div class="tab" data-group="primary" data-tab="breaths">
      <div class="grid two-col">
        <div class="field">
          <h3>Souffles possedes</h3>
          <button type="button" class="bl-custom-breath-builder">Calculateur souffle maison</button>
          {{#if ownedBreathItems.length}}
            <div class="breath-card-list">
              {{#each ownedBreathItems as |it|}}
                <article class="breath-card item" data-item-id="{{it.id}}">
                  <img class="breath-card__img" src="{{it.img}}" alt="{{it.name}}" />
                  <div class="breath-card__body">
                    <div class="breath-card__topline">
                      <strong><a class="item-edit">{{it.name}}</a></strong>
                      <span>{{#if it.actorEnabled}}Actif{{else}}Inactif{{/if}}</span>
                    </div>
                    {{#if it.sourceSection}}<small>{{it.sourceSection}}</small>{{/if}}
                    {{#if it.prereqText}}<p>Prerequis: {{it.prereqText}}</p>{{/if}}
                    {{#if it.description}}<p>{{it.description}}</p>{{/if}}
                    {{#if it.itemSpecials.length}}
                      <div class="tag-row">
                        {{#each it.itemSpecials as |special|}}
                          <span class="tag">{{special}}</span>
                        {{/each}}
                      </div>
                    {{/if}}
                  </div>
                  <div class="controls">
                    <a class="item-control item-edit" title="Ouvrir"><i class="fas fa-pen-to-square"></i></a>
                    <a class="item-control item-delete" title="Supprimer"><i class="fas fa-trash"></i></a>
                  </div>
                </article>
              {{/each}}
            </div>
          {{else}}
            <p class="hint">Aucun objet de type souffle n'est encore ajoute a l'acteur.</p>
          {{/if}}
        </div>

        <div class="field">
          <h3>Activation & passifs</h3>
          <div class="grid two-col breath-toggle-grid">
            {{#each breathEntries as |entry|}}
              <div class="field">
                <label>
                  <input type="checkbox" name="system.breaths.{{entry.key}}.enabled" data-dtype="Boolean" {{checked entry.enabled}} {{#unless ../canEdit}}disabled{{/unless}} />
                  {{entry.label}}
                </label>
                {{#if entry.specialEntries.length}}
                  <div class="small muted">Passifs d'acteur</div>
                  {{#each entry.specialEntries as |special|}}
                    <label class="small" title="{{special.hint}}">
                      <input type="checkbox" name="system.breaths.{{../key}}.specials.{{special.key}}" data-dtype="Boolean" {{checked special.enabled}} {{#unless ../../canEdit}}disabled{{/unless}} />
                      {{special.label}}
                    </label>
                  {{/each}}
                {{/if}}
              </div>
            {{/each}}
          </div>
        </div>
      </div>

      <h3>Maitrises avancees</h3>
      <div class="grid two-col">
        {{#each advancedStateEntries as |state|}}
          <label class="field">
            <input type="checkbox" name="system.states.{{state.key}}" data-dtype="Boolean" {{checked state.active}} {{#unless ../canEdit}}disabled{{/unless}} />
            <strong>{{state.label}}</strong>
            <small>{{state.note}}</small>
          </label>
        {{/each}}
      </div>
    </div>

    <div class="tab" data-group="primary" data-tab="techniques">
      <div class="field">
        <label>Recherche</label>
        <input type="text" data-tech-filter placeholder="Nom, souffle, forme, tag..." />
      </div>
      <header class="list-header">
        <div>Nom</div><div>Famille</div><div>Forme</div><div>Cout</div><div>Degats</div><div></div>
      </header>
      <ol class="item-list">
        {{#each itemsTech as |it|}}
          <li class="item technique-item" data-item-id="{{it.id}}" data-search="{{it.name}} {{it.type}} {{it.system.breathDisplay}} {{it.system.tags}}">
            <div class="name"><a class="item-edit">{{it.name}}</a></div>
            <div>{{#if it.system.breathDisplay}}{{it.system.breathDisplay}}{{else}}{{it.type}}{{/if}}{{#if it.blMissingBreath}} <small>(souffle manquant)</small>{{/if}}</div>
            <div>{{it.system.form}}</div>
            <div>{{it.system.costE}}{{#if it.system.costRp}} / RP {{it.system.costRp}}{{/if}}{{#if it.system.costBdp}} / BDP {{it.system.costBdp}}{{/if}}</div>
            <div>{{#if it.system.damage}}{{it.system.damage}}{{else}}-{{/if}}</div>
            <div class="controls">
              <a class="item-control item-chat" title="Utiliser"><i class="fas fa-burst"></i></a>
              <a class="item-control item-edit" title="Ouvrir"><i class="fas fa-pen-to-square"></i></a>
              <a class="item-control item-delete" title="Supprimer"><i class="fas fa-trash"></i></a>
            </div>
          </li>
        {{/each}}
      </ol>
    </div>

    <div class="tab" data-group="primary" data-tab="inventaire">
      <div class="grid two-col">
        <div class="field">
          <h3>Poison actif</h3>
          <div class="rule-pills">
            <div class="rule-pill">
              <span>{{activePoisonSummary.title}}</span>
              <strong>{{#if activePoisonSummary.active}}Dose prete{{else}}Aucune dose{{/if}}</strong>
              {{#each activePoisonSummary.lines as |line|}}
                <small>{{line}}</small>
              {{/each}}
            </div>
          </div>
          {{#if activePoisonSummary.active}}
            <button type="button" class="bl-clear-poison">Retirer l'enduction</button>
          {{/if}}
        </div>

        <div class="field">
          <h3>Etat du poison</h3>
          <div class="rule-pills">
            <div class="rule-pill">
              <span>{{poisonStateSummary.profileLabel}}</span>
              <strong>{{poisonStateSummary.intensity}} niveau(x)</strong>
              <small>{{poisonStateSummary.effectSummary}}</small>
              {{#if poisonStateSummary.restrictionSummary}}<small>{{poisonStateSummary.restrictionSummary}}</small>{{/if}}
            </div>
          </div>
        </div>
      </div>

      <h3>Poisons</h3>
      <header class="list-header">
        <div>Nom</div><div>Profil</div><div></div>
      </header>
      <ol class="item-list">
        {{#each itemsPoisons as |it|}}
          <li class="item" data-item-id="{{it.id}}">
            <div class="name"><a class="item-edit">{{it.name}}</a><br><small>{{it.blChargeLabel}}</small></div>
            <div>{{it.blProfileLabel}}</div>
            <div class="controls">
              <a class="item-control bl-apply-poison" title="Enduire une arme"><i class="fas fa-vial"></i></a>
              <a class="item-control item-edit" title="Ouvrir"><i class="fas fa-pen-to-square"></i></a>
              <a class="item-control item-delete" title="Supprimer"><i class="fas fa-trash"></i></a>
            </div>
          </li>
        {{/each}}
      </ol>

      <h3>Armes</h3>
      <header class="list-header">
        <div>Nom</div><div>Type</div><div></div>
      </header>
      <ol class="item-list">
        {{#each itemsWeapons as |it|}}
          <li class="item" data-item-id="{{it.id}}">
            <div class="name">
              <a class="item-edit">{{it.name}}</a>
              {{#if it.system.usesAmmo}}<br><small>Munitions: {{it.system.ammo.value}} / {{it.system.ammo.max}}</small>{{/if}}
            </div>
            <div>{{it.type}}</div>
            <div class="controls">
              <a class="item-control bl-weapon-attack" title="Attaque"><i class="fas fa-swords"></i></a>
              {{#if it.system.usesAmmo}}
                <a class="item-control bl-weapon-reload" title="Recharger"><i class="fas fa-rotate-right"></i></a>
              {{/if}}
              <a class="item-control item-edit" title="Ouvrir"><i class="fas fa-pen-to-square"></i></a>
              <a class="item-control item-delete" title="Supprimer"><i class="fas fa-trash"></i></a>
            </div>
          </li>
        {{/each}}
      </ol>

      <h3>Medical & soutien</h3>
      <header class="list-header">
        <div>Nom</div><div>Type</div><div></div>
      </header>
      <ol class="item-list">
        {{#each itemsMedical as |it|}}
          <li class="item" data-item-id="{{it.id}}">
            <div class="name"><a class="item-edit">{{it.name}}</a></div>
            <div>{{it.type}}</div>
            <div class="controls">
              <a class="item-control bl-use-medical" title="Utiliser"><i class="fas fa-kit-medical"></i></a>
              <a class="item-control item-edit" title="Ouvrir"><i class="fas fa-pen-to-square"></i></a>
              <a class="item-control item-delete" title="Supprimer"><i class="fas fa-trash"></i></a>
            </div>
          </li>
        {{/each}}
      </ol>

      <h3>Autres objets</h3>
      <header class="list-header">
        <div>Nom</div><div>Type</div><div></div>
      </header>
      <ol class="item-list">
        {{#each itemsOtherInventory as |it|}}
          <li class="item" data-item-id="{{it.id}}">
            <div class="name"><a class="item-edit">{{it.name}}</a></div>
            <div>{{it.type}}</div>
            <div class="controls">
              {{#if (eq it.type "transport")}}
                <a class="item-control bl-drive-relaxed" title="Conduite detendue"><i class="fas fa-road"></i></a>
                <a class="item-control bl-drive-danger" title="Conduite dangereuse"><i class="fas fa-triangle-exclamation"></i></a>
              {{/if}}
              {{#if (eq it.type "vehicle")}}
                <a class="item-control bl-drive-relaxed" title="Conduite detendue"><i class="fas fa-road"></i></a>
                <a class="item-control bl-drive-danger" title="Conduite dangereuse"><i class="fas fa-triangle-exclamation"></i></a>
              {{/if}}
              {{#if it.system.crafting.enabled}}
                <a class="item-control bl-crafting-check" title="Fabrication"><i class="fas fa-hammer"></i></a>
              {{/if}}
              <a class="item-control item-edit" title="Ouvrir"><i class="fas fa-pen-to-square"></i></a>
              <a class="item-control item-delete" title="Supprimer"><i class="fas fa-trash"></i></a>
            </div>
          </li>
        {{/each}}
      </ol>
    </div>

    <div class="tab" data-group="primary" data-tab="regles">
      <div class="grid three-col">
        <div class="field">
          <h3>Economies d'action</h3>
          <label>Actions / tour</label>
          <input type="number" name="system.combat.actionEconomy.actionsPerTurn" value="{{system.combat.actionEconomy.actionsPerTurn}}" min="1" {{#unless canEdit}}disabled{{/unless}} />
          <label>Actions bonus</label>
          <input type="number" name="system.combat.actionEconomy.bonusActions" value="{{system.combat.actionEconomy.bonusActions}}" min="0" {{#unless canEdit}}disabled{{/unless}} />
          <label>Deplacement (m)</label>
          <input type="number" name="system.combat.actionEconomy.movementMeters" value="{{system.combat.actionEconomy.movementMeters}}" min="0" step="0.5" {{#unless canEdit}}disabled{{/unless}} />
          <small>Effectif: {{system.combat.actionEconomy.effectiveMovementMeters}} m{{#if system.combat.injuries.noFlight}} - vol impossible{{/if}}</small>
          {{#if system.combat.injuries.limbEffectSummary.length}}
            <small>{{join system.combat.injuries.limbEffectSummary ", "}}</small>
          {{/if}}
          <label>Reaction medicale</label>
          <input type="checkbox" name="system.support.medicalTraining" data-dtype="Boolean" {{checked system.support.medicalTraining}} {{#unless canEdit}}disabled{{/unless}} />
          <label>Degats temporaires</label>
          <input type="number" name="system.combat.damageFlat" value="{{system.combat.damageFlat}}" {{#unless canEdit}}disabled{{/unless}} />
        </div>

        <div class="field">
          <h3>Conditions</h3>
          <div class="condition-list">
            {{#each conditionEntries as |entry|}}
              <div class="condition-row">
                <label>
                  <input type="checkbox" name="system.conditions.{{entry.key}}.active" data-dtype="Boolean" {{checked entry.state.active}} {{#unless ../canEdit}}disabled{{/unless}} />
                  {{entry.label}}
                </label>
                <input type="number" name="system.conditions.{{entry.key}}.intensity" value="{{entry.state.intensity}}" min="0" placeholder="Niv." {{#unless ../canEdit}}disabled{{/unless}} />
                <input type="number" name="system.conditions.{{entry.key}}.duration" value="{{entry.state.duration}}" min="0" placeholder="Tours" {{#unless ../canEdit}}disabled{{/unless}} />
              </div>
            {{/each}}
          </div>
        </div>

        <div class="field">
          <h3>Mutilation & mort</h3>
          <label>Etat vital</label>
          <select name="system.death.state" {{#unless canEdit}}disabled{{/unless}}>
            {{#each deathStates as |st|}}
              <option value="{{st.value}}" {{#if (eq ../system.death.state st.value)}}selected{{/if}}>{{st.label}}</option>
            {{/each}}
          </select>
          <label>Blessures severes</label>
          <input type="number" name="system.combat.injuries.severeWounds" value="{{system.combat.injuries.severeWounds}}" min="0" {{#unless canEdit}}disabled{{/unless}} />
          <label>Blessures quasi mortelles</label>
          <input type="number" name="system.combat.injuries.nearDeathWounds" value="{{system.combat.injuries.nearDeathWounds}}" min="0" {{#unless canEdit}}disabled{{/unless}} />
          <label>Mort debout</label>
          <input type="checkbox" name="system.death.standingDeath" data-dtype="Boolean" {{checked system.death.standingDeath}} {{#unless canEdit}}disabled{{/unless}} />
          <label>Notes</label>
          <textarea name="system.death.deathNotes" rows="2" {{#unless canEdit}}disabled{{/unless}}>{{system.death.deathNotes}}</textarea>
        </div>
      </div>

      <h3>Etats des membres</h3>
      <div class="grid three-col">
        {{#each limbEntries as |entry|}}
          <div class="field">
            <strong>{{entry.label}}</strong>
            <small>Seuil {{entry.thresholdPercent}}% - suivi: {{entry.targetedDamage}}</small>
            <label><input type="checkbox" name="system.combat.injuries.limbs.{{entry.key}}.injured" data-dtype="Boolean" {{checked entry.state.injured}} {{#unless ../canEdit}}disabled{{/unless}} /> Blesse</label>
            <label><input type="checkbox" name="system.combat.injuries.limbs.{{entry.key}}.broken" data-dtype="Boolean" {{checked entry.state.broken}} {{#unless ../canEdit}}disabled{{/unless}} /> Casse</label>
            <label><input type="checkbox" name="system.combat.injuries.limbs.{{entry.key}}.severed" data-dtype="Boolean" {{checked entry.state.severed}} {{#unless ../canEdit}}disabled{{/unless}} /> Sectionne</label>
            <textarea name="system.combat.injuries.limbs.{{entry.key}}.notes" rows="2" placeholder="Notes" {{#unless ../canEdit}}disabled{{/unless}}>{{entry.state.notes}}</textarea>
          </div>
        {{/each}}
      </div>
    </div>
  </section>
</form>
