<form class="bl item-breath flexcol" autocomplete="off">
  <header class="sheet-header flexrow">
    <img class="profile" src="{{resolvedImg}}" data-edit="img" title="{{item.name}}" />
    <div class="header-fields">
      <h1 class="charname">
        <input name="name" type="text" value="{{item.name}}" placeholder="Souffle..." />
      </h1>

      <div class="flexrow gap">
        <div class="field">
          <label>Cle systeme</label>
          <select name="system.key">
            {{selectOptions keyOptions selected=system.key}}
          </select>
        </div>
        <div class="field">
          <label>Activer pour l'acteur</label>
          <input type="checkbox" name="system.enabled" data-dtype="Boolean" {{checked system.enabled}} />
        </div>
      </div>
    </div>
  </header>

  <nav class="sheet-tabs tabs" data-group="primary">
    <a class="item" data-tab="specials">Capacites speciales</a>
    <a class="item" data-tab="prereq">Prerequis</a>
    <a class="item" data-tab="desc">Description</a>
  </nav>

  <section class="sheet-body">
    <div class="tab" data-group="primary" data-tab="specials">
      <div class="grid specials">
        {{#each system.specialsDisplay as |spec key|}}
          <label class="checkbox" title="{{spec.hint}}">
            <input type="checkbox" name="system.specials.{{key}}" data-dtype="Boolean" {{checked spec.enabled}} />
            <span>{{spec.label}}</span>
          </label>
        {{/each}}
      </div>
      {{#unless hasSpecials}}
        <p class="hint" style="opacity:.8;">Choisis la <b>cle systeme</b> du souffle pour voir ses capacites speciales.</p>
      {{/unless}}
    </div>

    <div class="tab" data-group="primary" data-tab="prereq">
      <div class="grid prereq">
        <label>Sens requis</label>
        <input type="text" name="system.prereq.sense" value="{{system.prereq.sense}}" />

        <label>Caracteristiques</label>
        <input type="text" name="system.prereq.stats" value="{{system.prereq.stats}}" />

        <label>Armes</label>
        <input type="text" name="system.prereq.weapons" value="{{system.prereq.weapons}}" />
      </div>
    </div>

    <div class="tab" data-group="primary" data-tab="desc">
      <textarea name="system.description" rows="12">{{system.description}}</textarea>
    </div>
  </section>
</form>
