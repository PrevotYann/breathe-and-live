{"_id":"tech-moon-14-catastrophe-tenman-lune-croissante","name":"Catastrophe, Tenman Lune Croissante","type":"technique","img":"icons/magic/light/projectile-moon.webp","system":{"breath":"Souffle de la Lune","breathKey":"moon","breathLabel":"Souffle de la Lune","form":14,"costE":18.0,"costRp":0,"costBdp":0,"damage":"2d20 + Force","damageText":"2d20 + Force","range":9.0,"rangeText":"9m","modifierText":"Force","attackStat":"force","autoHit":true,"isBreath":true,"sourceSection":"Souffle de la Lune","description":"L'épéiste crée un anneau de coups en expansion à partir d'un point central, envoyant des lames en forme de croissant dans toutes les directions. Chaque vague devient de plus en plus large.","usageNote":"","tags":["breath","moon"],"specialLines":[],"automation":{"requiresBreath":true,"area":"single","alternativeMode":"","lineOnly":false,"ranged":false,"unlimitedRange":false,"chargeTurns":0,"cooldownTurns":0,"cannotBeDodged":false,"cannotBeReactedTo":false,"deflect":false,"negateIncomingDamage":false,"afflictionStacks":0,"enduranceRestore":"none"},"flags":{"aoe":false,"antiFriendlyFire":false,"mobility":false,"decapitation":false,"charge":0,"deflect":false}}}
