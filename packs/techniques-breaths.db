{"_id":"tech-moon-04-lune-voilee-poussiere-fantomatique","name":"Lune Voilée, Poussière Fantomatique","type":"technique","img":"icons/magic/light/projectile-moon.webp","system":{"breath":"Souffle de la Lune","breathKey":"moon","breathLabel":"Souffle de la Lune","form":4,"costE":1.0,"costRp":0,"costBdp":0,"damage":"1d12 + Finesse","damageText":"1d12 + Finesse\n\nEn ligne droite\n*Doit se déplacer dans une seule direction","range":3.0,"rangeText":"3m","modifierText":"Finesse","attackStat":"finesse","autoHit":true,"isBreath":true,"sourceSection":"Souffle de la Lune","description":"L'épéiste avance en décrivant un arc étroit, générant une lame en forme de croissant de lune qui se déplace dans une ligne focalisée et perçante. Ce mouvement est conçu pour percer les armures ou transpercer plusieurs cibles successives.","usageNote":"","tags":["breath","moon"],"specialLines":["En ligne droite","*Doit se déplacer dans une seule direction"],"automation":{"requiresBreath":true,"area":"single","alternativeMode":"","lineOnly":true,"ranged":false,"unlimitedRange":false,"chargeTurns":0,"cooldownTurns":0,"cannotBeDodged":false,"cannotBeReactedTo":false,"deflect":false,"negateIncomingDamage":false,"afflictionStacks":0,"enduranceRestore":"none"},"flags":{"aoe":false,"antiFriendlyFire":false,"mobility":true,"decapitation":false,"charge":0,"deflect":false}}}
