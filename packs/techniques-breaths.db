{"_id":"techMoon11b000","name":"Lune Creuse","type":"technique","img":"icons/magic/light/explosion-star-large-purple.webp","system":{"breath":"Souffle de la Lune","breathKey":"moon","breathLabel":"Souffle de la Lune","form":11,"costE":7.0,"costRp":0,"costBdp":0,"damage":"1d6 + Force/Finesse","damageText":"1d6 + Force/Finesse\n\nDéflecteur / Annulateur\n*Annule les dégâts subis","range":6.0,"rangeText":"6m","modifierText":"Force / Finesse","attackStat":"force-or-finesse","autoHit":true,"isBreath":true,"sourceSection":"Souffle de la Lune","description":"L'épéiste tord son corps dans une spirale dans les airs, frappant avec une toile d'arcs en croissant dans toutes les directions.","usageNote":"","tags":["breath","moon","deflect"],"specialLines":["Déflecteur / Annulateur","*Annule les dégâts subis"],"automation":{"requiresBreath":true,"area":"single","alternativeMode":"","lineOnly":false,"ranged":false,"unlimitedRange":false,"chargeTurns":0,"cooldownTurns":0,"cannotBeDodged":false,"cannotBeReactedTo":false,"deflect":true,"negateIncomingDamage":true,"afflictionStacks":0,"enduranceRestore":"none"},"flags":{"aoe":false,"antiFriendlyFire":false,"mobility":false,"decapitation":false,"charge":0,"deflect":true}}}
